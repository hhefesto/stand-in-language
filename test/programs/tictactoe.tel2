# Tic-tac-toe as a finite-grid-game algebra. Player 1/X starts.
telomare-grid-game 1

board 3 3
cells 9

player "Player 1" "X"
player "Player 2" "O"

moves "1" "2" "3" "4" "5" "6" "7" "8" "9"
quit "q" "Goodbye.\n"

winning 1 2 3
winning 4 5 6
winning 7 8 9
winning 1 4 7
winning 2 5 8
winning 3 6 9
winning 1 5 9
winning 3 5 7

cell-separator "|"
row-separator "\n-+-+-\n"
turn-message "{player}/{mark} to move.\n"
prompt "Move (1-9 or q): "
invalid-message "Invalid input; enter 1-9 or q.\n"
occupied-message "That square is occupied.\n"
win-message "{player}/{mark} wins!\n"
tie-message "Tie game.\n"

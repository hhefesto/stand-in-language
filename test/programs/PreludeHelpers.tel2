module PreludeHelpers
import Prelude

type State = Nat

main : Text * State -o Reply State = \x ->
  let (input, state) = x
   in case state of
        0 -> let _ = input
              in ("", right (boolToNat (boolAnd (True, boolNot False))))
        n -> let _ = n
                 length = listLength input
              in case length of
                   5 -> ("true\n", left ())
                   k -> let _ = k in ("false\n", left ())

module PreludeHelpers;
import Prelude;

type State = Nat;
def init(u: Unit): Reply State =
  ("",right (boolToNat (boolAnd (True, boolNot False))));
def step(x: Text * State): Reply State =
  let (input,state) = x in
  let _ = state in
  let length = listLength input in
  matchNat length of { 5 -> ("true\n",left ()); n -> ("false\n",left ()) };

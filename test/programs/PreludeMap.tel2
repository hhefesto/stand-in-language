module PreludeMap;
import Prelude;

type State = Unit;

def init(u: Unit): Reply State =
  let _: Unit = u in ("",right ());

def step(request: Text * State): Reply State =
  let (input,state): Text * State = request in
  let _: State = state in
  let output: Text = mapIncrement(input) in
  matchText output of {
    "BCD" -> ("mapped\n",left ());
    other -> ("bad\n",left ());
  };

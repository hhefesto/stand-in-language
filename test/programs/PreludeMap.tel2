module PreludeMap
import Prelude

type State = Nat

main : Text * State -o Reply State = \request ->
  let (input, state) = request
   in case state of
        0 -> let _ = input in ("", right 1)
        n -> let _ = n
                 output = mapIncrement input
              in case output of
                   "BCD" -> ("mapped\n", left ())
                   other -> let _ = other in ("bad\n", left ())

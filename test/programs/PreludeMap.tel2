module PreludeMap;
import Prelude;

type State = Unit;

def init(u: Unit): Reply State =
  let _ = u in ("",right ());

def step(request: Text * State): Reply State =
  let (input,state) = request in
  let _ = state in
  let output = mapIncrement input in
  matchText output of {
    "BCD" -> ("mapped\n",left ());
    other -> ("bad\n",left ());
  };
